// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 💡 TIPS UMUM IMPLEMENTASI (FRONTEND/BACKEND):
// 1. DECIMAL: Prisma mengembalikan Decimal sebagai Object. 
//    Saat di frontend, konversi dulu: Number(value) atau value.toNumber().
// 2. ERROR HANDLING: Selalu gunakan try-catch saat query database.
// 3. TRANSFORMER: Pastikan tRPC menggunakan 'superjson' untuk handle Date & Decimal.
// ==========================================

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 💡 TIPS LOGIKA: Cek apakah kategori kosong sebelum menghapus.
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  image       String? // URL gambar dari Supabase Storage

  // 💡 TIPS SOFT DELETE (SANGAT PENTING): 
  // Jangan pernah melakukan hard delete jika produk sudah pernah terjual.
  // Cukup lakukan update: isAvailable = false.
  isAvailable Boolean @default(true)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  transactionItems TransactionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model Transaction {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique // Generate di frontend: INV-YYYYMMDD-XXXX
  date          DateTime      @default(now())
  totalAmount   Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  paidAmount    Decimal       @db.Decimal(12, 2)
  change        Decimal       @db.Decimal(12, 2)

  // 💡 TIPS PWA (OFFLINE FIRST): 
  // false = Tersimpan di IndexedDB browser (Offline).
  // true  = Berhasil di-upload ke server Supabase (Online).
  isSynced Boolean @default(false)

  items TransactionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([isSynced])
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  // 💡 TIPS SNAPSHOT (Laporan Keuangan Akurat): 
  // Nilai di bawah ini harus DI-COPY dari Product saat transaksi terjadi.
  // Ini menjaga akurasi laporan keuangan meski harga master berubah di masa depan.
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  subTotal    Decimal @db.Decimal(12, 2)
  note        String? // Catatan khusus (Pedas, Bungkus, dll)

  @@index([transactionId])
}

// 💡 MEMENUHI TABEL UJI 3.8 POIN 7 (PENGATURAN PROFIL TOKO)
model StoreConfig {
  id      Int     @id @default(1)
  name    String  @default("Mie Jawa Melati")
  address String? @default("Jl. Nasional III, Blitar")
  phone   String?
  logoUrl String? // Tambahan kolom baru untuk Logo

  updatedAt DateTime @updatedAt
}
