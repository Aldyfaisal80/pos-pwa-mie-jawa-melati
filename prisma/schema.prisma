// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {  
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}


enum PaymentMethod {
    CASH
    QRIS
    TRANSFER
}

model Category {
    id       Int       @id @default(autoincrement())
    name     String
    products Product[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([name])
}

model Product {
    id          String  @id @default(uuid())
    name        String
    description String?
    price       Decimal @db.Decimal(10, 2)
    image       String?

    isAvailable Boolean @default(true)

    categoryId Int
    category   Category @relation(fields: [categoryId], references: [id])

    transactionItems TransactionItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([categoryId])
}

model Transaction {
    id            String        @id @default(uuid())
    invoiceNumber String        @unique // Generate di frontend: INV-YYYYMMDD-XXXX
    date          DateTime      @default(now())
    totalAmount   Decimal       @db.Decimal(12, 2)
    paymentMethod PaymentMethod @default(CASH)
    paidAmount    Decimal       @db.Decimal(12, 2)
    change        Decimal       @db.Decimal(12, 2)

    isSynced  Boolean   @default(false)
    deletedAt DateTime? // null = active, set = soft-deleted

    items TransactionItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([date])
    @@index([isSynced])
    @@index([deletedAt])
    @@index([isSynced, deletedAt, date])
}


model TransactionItem {
    id            String      @id @default(uuid())
    transactionId String
    transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
    productId     String
    product       Product     @relation(fields: [productId], references: [id])

    productName String
    quantity    Int
    unitPrice   Decimal @db.Decimal(10, 2)
    subTotal    Decimal @db.Decimal(12, 2)
    note        String?

    @@index([transactionId])
}

model StoreConfig {
    id        Int     @id @default(1)
    name      String  @default("Mie Jawa Melati")
    address   String? @default("Jl. Nasional III, Blitar")
    phone     String?
    logoUrl   String? // Tambahan kolom baru untuk Logo

    updatedAt DateTime @updatedAt
}
